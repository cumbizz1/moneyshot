    "jsonwebtoken": "^8.5.1",
    "lodash": "^4.17.21",
    "migrate": "^1.8.0",
    "mkdirp": "^1.0.4",
    "moment": "^2.29.3",
    "mongodb": "^4.7.0",
    "mongoose": "^6.4.0",
    "multer": "^1.4.2",
